<?xml version="1.0" encoding="utf-8" ?>
<component name="HeroUnit" extends="Group">
  <script type="text/brightscript" uri="HeroUnit.bs" />
  <interface>
    <field id="content" type="node" onChange="onContentChanged" />
  </interface>
  <children>
    <Poster id="poster" width="1800" height="450" loadDisplayMode="scaleToZoom" />
    <!-- Bottom scrim improves text legibility over bright posters. -->
    <Rectangle id="scrim" translation="[0, 280]" width="1800" height="170" color="0x000000AA" />
    <Label id="title" translation="[40, 290]" width="1100" font="font:LargeBoldSystemFont" color="0xFFFFFFFF" />
    <Label id="synopsis" translation="[40, 345]" width="1100" color="0xCCCCCCFF" wrap="true" />
    <Button
      id="playButton"
      text="Play Now"
      iconUri="pkg:/images/play-icon-light.png"
      focusedIconUri="pkg:/images/play-icon-dark.png"
      translation="[40, 386]"
      minWidth="220"
    />
  </children>
</component>
